generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  vehicles     Vehicle[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Vehicle {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  year               Int
  make               String
  model              String
  trim               String?
  vin                String?
  mileage            Int
  annualMiles        Int                 @default(12000)
  purchasePrice      Float
  purchaseDate       DateTime
  color              String?
  imageUrl           String?
  loan               Loan?
  warranties         Warranty[]
  maintenanceRecords MaintenanceRecord[]
  insurancePolicies  Insurance[]
  modifications      Modification[]
  marketValues       MarketValue[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId])
}

model Loan {
  id             String   @id @default(cuid())
  vehicleId      String   @unique
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  originalAmount Float
  currentBalance Float
  apr            Float
  termMonths     Int
  monthlyPayment Float
  startDate      DateTime
  lender         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Warranty {
  id                String    @id @default(cuid())
  vehicleId         String
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type              String // factory, extended, powertrain, bumper-to-bumper
  provider          String?
  expirationDate    DateTime?
  expirationMileage Int?
  cost              Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([vehicleId])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String // oil-change, tires, brakes, fluid, inspection, repair, other
  description String
  cost        Float
  mileage     Int
  shop        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vehicleId])
}

model Insurance {
  id             String    @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  provider       String
  policyNumber   String?
  monthlyPremium Float
  deductible     Float?
  coverageType   String // full, liability, comprehensive
  startDate      DateTime
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([vehicleId])
}

model Modification {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name        String
  category    String // performance, appearance, interior, wheels-tires, suspension, exhaust, lighting, audio
  cost        Float
  date        DateTime
  description String?
  shop        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vehicleId])
}

model MarketValue {
  id             String   @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  estimatedValue Float
  source         String // cars-and-bids, bring-a-trailer, manual, kbb
  url            String?
  fetchedAt      DateTime @default(now())

  @@index([vehicleId])
}
